rules_version = '2';
// Bu Yunanca uygulaması veriyi `global` koleksiyonunda tutar (örn. global/users, global/userdata).
// Ayrıca başka bir yapı için `users/{userId}` altında Auth tabanlı kurallar kullanıyorsanız aşağıdaki blok kalır.
service cloud.firestore {
  match /databases/{database}/documents {

    // (Sizin mevcut kuralınız) Firebase ile giriş yapmış kullanıcı kendi alt yoluna erişsin
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Yunanca Okulu (www.yunancaokulu.com) — Firebase Auth kullanmadan istemciden okuma/yazma (mevcut kod bu yapıda)
    match /global/{docId} {
      allow read, write: if true;
    }
  }
}
